# Docker Compose environment overrides

# Frontend published port
FRONTEND_PORT=8090

# Optional Redis for backend distributed cache/rate-limit
# REDIS_URL=redis://host.docker.internal:6379

# Code execution provider configuration
CODE_EXEC_PROVIDER=judge0
CODE_EXEC_API_URL=
# If empty, backend automatically uses built-in local JS sandbox fallback
CODE_EXEC_ENABLE_FALLBACK=true
CODE_EXEC_FALLBACK_PROVIDER=local-js
CODE_EXEC_FALLBACK_API_URL=
CODE_EXEC_API_KEY=
CODE_EXEC_API_HOST=judge0-ce.p.rapidapi.com

# OpenAI adaptive coaching
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# YouTube personalized feed
YOUTUBE_API_KEY=
