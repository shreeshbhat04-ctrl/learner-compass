NODE_ENV=production
HOST=0.0.0.0
PORT=4000
REQUEST_TIMEOUT_MS=12000
KEEP_ALIVE_TIMEOUT_MS=72000
RATE_LIMIT_MAX_PER_MINUTE=300
MAX_SEARCH_RESULTS=50
SEARCH_CACHE_TTL_MS=30000
SEARCH_CACHE_MAX_ENTRIES=2000
SEARCH_CACHE_REDIS_KEY_PREFIX=search:
# Optional for multi-instance cache/rate-limits:
# REDIS_URL=redis://<host>:6379

# Code execution provider (Judge0-compatible):
CODE_EXEC_PROVIDER=judge0
# Example: https://judge0-ce.p.rapidapi.com  or your self-hosted Judge0 URL
CODE_EXEC_API_URL=
# Built-in local JavaScript sandbox fallback when CODE_EXEC_API_URL is empty:
CODE_EXEC_ENABLE_FALLBACK=true
# Fallback runtime when primary provider is unavailable:
CODE_EXEC_FALLBACK_PROVIDER=local-js
# Optional external fallback endpoint (leave empty for built-in local-js fallback):
CODE_EXEC_FALLBACK_API_URL=
# Optional for Judge0 auth / required for RapidAPI provider:
CODE_EXEC_API_KEY=
# Required when CODE_EXEC_PROVIDER=rapidapi-judge0
CODE_EXEC_API_HOST=judge0-ce.p.rapidapi.com
CODE_EXEC_REQUEST_TIMEOUT_MS=12000
CODE_EXEC_POLL_INTERVAL_MS=700
CODE_EXEC_POLL_ATTEMPTS=20
CODE_EXEC_MAX_TEST_CASES=20
CODE_EXEC_MAX_SOURCE_CHARS=20000

# OpenAI adaptive coaching (profile insight, gap analysis, hint-only help):
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REQUEST_TIMEOUT_MS=18000
OPENAI_MAX_CONTEXT_CHARS=12000

# YouTube personalized learning feed:
YOUTUBE_API_KEY=
YOUTUBE_API_URL=https://www.googleapis.com/youtube/v3
YOUTUBE_DEFAULT_MAX_RESULTS=6
YOUTUBE_REQUEST_TIMEOUT_MS=10000
